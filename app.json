{
  "expo": {
    "name": "GenTech",
    "slug": "gentech-repair",
    "version": "1.0.1",
    "scheme": "gentech",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.gentech.repairshop",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gentech.repairshop"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GenTech to access your photos.",
          "cameraPermission": "Allow GenTech to use your camera to capture device photos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5c72a796-3aaf-41b6-9740-8cc2043e8d60"
      }
    }
  }
}
